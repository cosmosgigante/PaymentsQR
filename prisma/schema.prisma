generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String       @id @default(cuid())
  ownerEmail            String       @unique
  name                  String?
  planType              String?      // "MENSUAL" | "TRIMESTRAL" | "ANUAL"
  priceArs              Int?         // precio total de la cuenta (base + extras), en ARS
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  paymentSource         String?      @default("MANUAL") // "MANUAL" | "WEB"
  isActive              Boolean      @default(true)
  canceledAt            DateTime?    // si el cliente canceló el plan (sigue activo hasta subscriptionEndsAt)
  restaurants           Restaurant[]
  admins                Admin[]
  accessTokens          AccessToken[]
  createdAt             DateTime     @default(now())
}

// Credencial de acceso para el personal (la crea el cliente-administrador).
// Un token = un "login" (nombre + contraseña) con permisos, restoranes asignados,
// límite de dispositivos y vencimiento. Lo usan uno o varios dispositivos.
model AccessToken {
  id            String          @id @default(cuid())
  accountId     String
  account       Account         @relation(fields: [accountId], references: [id])
  name          String          // etiqueta: "Cocina", "Encargado", etc.
  authType      String          @default("PASSWORD") // "PASSWORD" | "GOOGLE"
  username      String?         @unique // login para authType PASSWORD (único global)
  passwordHash  String?         // para authType PASSWORD (generada por el sistema)
  email         String?         // email de Google para authType GOOGLE (único por cuenta)
  permissions   String          @default("{}")  // JSON: { "COCINA": "MANAGE", "MENU": "VIEW", ... }
  restaurantIds String          @default("[]")  // JSON: ids de restoranes asignados
  maxDevices    Int             @default(1)     // 1 a 10 dispositivos simultáneos
  expiresAt     DateTime?
  isActive      Boolean         @default(true)
  sessions      AccessSession[]
  createdAt     DateTime        @default(now())

  @@unique([accountId, email]) // mismo email puede existir en otra cuenta, no en la misma
}

// Sesión de un dispositivo usando un AccessToken (para límite de dispositivos
// y "ver tokens activos"). Se crea al loguear (Fase 2).
model AccessSession {
  id          String      @id @default(cuid())
  tokenId     String
  token       AccessToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  deviceLabel String?
  lastSeenAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
}

model Restaurant {
  id             String         @id @default(cuid())
  accountId      String?
  account        Account?       @relation(fields: [accountId], references: [id])
  name           String
  slug           String         @unique
  logo           String?
  primaryColor   String         @default("#f97316")
  isActive            Boolean        @default(true)
  status              String         @default("PENDING") // "PENDING" | "ACTIVE"
  // Columnas legacy: la suscripción real vive en Account. Se conservan porque
  // hay datos en producción (no las borramos para no perder información).
  subscriptionEndsAt    DateTime?
  subscriptionStartedAt DateTime?
  planType              String?
  extraBranches         Int            @default(0)
  priceArs              Int?
  paymentSource         String?        @default("MANUAL")
  maxTableDevices     Int            @default(2)     // dispositivos por sesión de mesa
  confirmTableEnabled Boolean        @default(false) // "confirmar mesa" antes de pedir (slice 2)
  tables         Table[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  tableSessions  TableSession[]
  admins         Admin[]
  createdAt      DateTime       @default(now())
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  number       Int
  label        String?
  qrToken      String     @unique @default(cuid())
  isActive     Boolean    @default(true)
  orders       Order[]
  tableSessions TableSession[]
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, number])
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  sortOrder    Int        @default(0)
  items        MenuItem[]
}

model MenuItem {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  price        Float
  image        String?
  available    Boolean      @default(true)
  sortOrder    Int          @default(0)
  orderItems   OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  status        String      @default("PENDING")
  paymentMode   String
  items         OrderItem[]
  total         Float
  notes         String?
  customerName  String?
  customerEmail String?
  tableSessionId String?
  tableSession   TableSession? @relation(fields: [tableSessionId], references: [id])
  deviceId       String?    // qué dispositivo de la mesa hizo el pedido (para dividir la cuenta)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([tableSessionId])
}

// Un intento de cobro (Checkout Pro). Cubre un conjunto FIJO de pedidos
// (snapshot al crearse) para que dividir la cuenta sea correcto con la plata.
model Payment {
  id           String       @id @default(cuid())
  sessionId    String
  session      TableSession @relation(fields: [sessionId], references: [id])
  restaurantId String
  deviceId     String?      // quién inició el pago
  scope        String       // "MINE" | "ALL"
  orderIds     String       @default("[]") // JSON: pedidos cubiertos por este pago
  amount       Float
  preferenceId String?
  status       String       @default("PENDING") // "PENDING" | "APPROVED"
  createdAt    DateTime     @default(now())
  paidAt       DateTime?

  @@index([sessionId])
}

// Sesión de mesa: agrupa los pedidos de un grupo de comensales sentados en una
// mesa, persistida en la base (no en memoria del navegador). Habilita historial
// real, límite de dispositivos por mesa, y confirmar/cerrar mesa (slices 2 y 3).
model TableSession {
  id             String     @id @default(cuid())
  tableId        String
  table          Table      @relation(fields: [tableId], references: [id])
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  status         String     @default("OPEN") // "OPEN" | "PENDING_CONFIRM" | "CLOSED"
  deviceIds      String     @default("[]")   // JSON: ids de dispositivos unidos (límite anti-escaneo ajeno)
  maxDevices     Int        @default(2)
  paymentStatus       String?  // null | "PENDING" (alguien inició el pago) | "APPROVED"
  paymentPreferenceId String?  // id de la preferencia de Checkout Pro vigente
  orders         Order[]
  payments       Payment[]
  openedAt       DateTime   @default(now())
  lastActivityAt DateTime   @default(now())
  confirmedAt    DateTime?
  closedAt       DateTime?

  @@index([tableId, status])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Float
  notes      String?
}

model RateLimit {
  id      String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model Admin {
  id           String     @id @default(cuid())
  accountId    String?
  account      Account?    @relation(fields: [accountId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  email        String      @unique
  passwordHash String?
  role         String     @default("STAFF")
  // Alcance de un socio dentro de la cuenta:
  //  FULL = como el dueño (todo); RESTRICTED = solo scopeRestaurantIds, sin poderes de cuenta
  accessScope       String  @default("FULL")  // "FULL" | "RESTRICTED"
  scopeRestaurantIds String @default("[]")    // JSON: restoranes asignados si RESTRICTED
  createdAt    DateTime   @default(now())
}

// Método de cobro de un restorán (lo carga el cliente-admin en Ajustes).
// El token va CIFRADO (AES-256-GCM, ver lib/secrets.ts) — nunca en texto plano,
// nunca vuelve al navegador. Solo el backend lo descifra al cobrar.
model PaymentMethod {
  id             String   @id @default(cuid())
  restaurantId   String
  provider       String   // "MERCADOPAGO"
  enabled        Boolean  @default(false)
  encryptedToken String?  // Access Token cifrado
  tokenHint      String?  // "••••1234" para mostrar sin revelar
  publicKey      String?  // public key de MP (es pública por diseño)
  accountName    String?  // nombre/email de la cuenta MP (validado al guardar)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([restaurantId, provider])
}

// Registro de actividad (auditoría). Sin relaciones para que el log sobreviva
// a borrados; se filtra por accountId / restaurantId.
model ActivityLog {
  id           String   @id @default(cuid())
  accountId    String?
  restaurantId String?
  actorType    String   // "OWNER" | "STAFF" | "SUPERADMIN" | "SYSTEM" | "CUSTOMER"
  actorName    String?  // email / nombre del acceso, para mostrar
  category     String   // "PERSONAL" | "PEDIDOS" | "MENU" | "MESAS" | "CUENTA"
  action       String   // "LOGIN" | "LOGOUT" | "ORDER_STATUS" | ...
  detail       String?  // texto legible
  createdAt    DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([restaurantId, createdAt])
}
