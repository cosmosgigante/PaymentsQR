generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                    String       @id @default(cuid())
  ownerEmail            String       @unique
  name                  String?
  planType              String?      // "MENSUAL" | "TRIMESTRAL" | "ANUAL"
  priceArs              Int?         // precio total de la cuenta (base + extras), en ARS
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?
  paymentSource         String?      @default("MANUAL") // "MANUAL" | "WEB"
  isActive              Boolean      @default(true)
  restaurants           Restaurant[]
  admins                Admin[]
  accessTokens          AccessToken[]
  createdAt             DateTime     @default(now())
}

// Credencial de acceso para el personal (la crea el cliente-administrador).
// Un token = un "login" (nombre + contraseña) con permisos, restoranes asignados,
// límite de dispositivos y vencimiento. Lo usan uno o varios dispositivos.
model AccessToken {
  id            String          @id @default(cuid())
  accountId     String
  account       Account         @relation(fields: [accountId], references: [id])
  name          String          // etiqueta: "Cocina", "Encargado", etc.
  authType      String          @default("PASSWORD") // "PASSWORD" | "GOOGLE"
  username      String?         @unique // login para authType PASSWORD
  passwordHash  String?         // para authType PASSWORD
  email         String?         @unique // email de Google para authType GOOGLE
  permissions   String          @default("{}")  // JSON: { "COCINA": "MANAGE", "MENU": "VIEW", ... }
  restaurantIds String          @default("[]")  // JSON: ids de restoranes asignados
  maxDevices    Int             @default(1)     // 1 a 10 dispositivos simultáneos
  expiresAt     DateTime?
  isActive      Boolean         @default(true)
  sessions      AccessSession[]
  createdAt     DateTime        @default(now())
}

// Sesión de un dispositivo usando un AccessToken (para límite de dispositivos
// y "ver tokens activos"). Se crea al loguear (Fase 2).
model AccessSession {
  id          String      @id @default(cuid())
  tokenId     String
  token       AccessToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  deviceLabel String?
  lastSeenAt  DateTime    @default(now())
  createdAt   DateTime    @default(now())
}

model Restaurant {
  id             String         @id @default(cuid())
  accountId      String?
  account        Account?       @relation(fields: [accountId], references: [id])
  name           String
  slug           String         @unique
  logo           String?
  primaryColor   String         @default("#f97316")
  isActive            Boolean        @default(true)
  status              String         @default("PENDING") // "PENDING" | "ACTIVE"
  subscriptionEndsAt  DateTime?      // legacy; la suscripción real vive en Account
  tables         Table[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  admins         Admin[]
  createdAt      DateTime       @default(now())
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  number       Int
  label        String?
  qrToken      String     @unique @default(cuid())
  isActive     Boolean    @default(true)
  orders       Order[]
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, number])
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  sortOrder    Int        @default(0)
  items        MenuItem[]
}

model MenuItem {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  price        Float
  image        String?
  available    Boolean      @default(true)
  sortOrder    Int          @default(0)
  orderItems   OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  status        String      @default("PENDING")
  paymentMode   String
  items         OrderItem[]
  total         Float
  notes         String?
  customerName  String?
  customerEmail String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Float
  notes      String?
}

model RateLimit {
  id      String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model Admin {
  id           String     @id @default(cuid())
  accountId    String?
  account      Account?    @relation(fields: [accountId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  email        String      @unique
  passwordHash String?
  role         String     @default("STAFF")
  createdAt    DateTime   @default(now())
}
