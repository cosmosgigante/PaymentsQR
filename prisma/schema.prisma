generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  logo           String?
  primaryColor   String         @default("#f97316")
  isActive            Boolean        @default(true)
  subscriptionEndsAt  DateTime?
  subscriptionStartedAt DateTime?
  planType            String?        // "MENSUAL" | "TRIMESTRAL" | "ANUAL"
  extraBranches       Int            @default(0)
  priceArs            Int?           // precio total cobrado, en ARS
  paymentSource       String?        @default("MANUAL") // "MANUAL" | "WEB"
  tables         Table[]
  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  admins         Admin[]
  createdAt      DateTime       @default(now())
}

model Table {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  number       Int
  label        String?
  qrToken      String     @unique @default(cuid())
  isActive     Boolean    @default(true)
  orders       Order[]
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, number])
}

model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  sortOrder    Int        @default(0)
  items        MenuItem[]
}

model MenuItem {
  id           String       @id @default(cuid())
  restaurantId String
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  categoryId   String
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  price        Float
  image        String?
  available    Boolean      @default(true)
  sortOrder    Int          @default(0)
  orderItems   OrderItem[]
}

model Order {
  id            String      @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant  @relation(fields: [restaurantId], references: [id])
  tableId       String
  table         Table       @relation(fields: [tableId], references: [id])
  status        String      @default("PENDING")
  paymentMode   String
  items         OrderItem[]
  total         Float
  notes         String?
  customerName  String?
  customerEmail String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Float
  notes      String?
}

model RateLimit {
  id      String   @id
  count   Int      @default(1)
  resetAt DateTime

  @@index([resetAt])
}

model Admin {
  id           String     @id @default(cuid())
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  email        String      @unique
  passwordHash String?
  role         String     @default("STAFF")
  createdAt    DateTime   @default(now())
}
